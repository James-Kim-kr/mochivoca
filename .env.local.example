# NextAuth 설정
# NEXTAUTH_SECRET: 아래 명령으로 안전한 시크릿을 생성하세요
#   PowerShell:  [Convert]::ToBase64String((1..32 | % { Get-Random -Maximum 256 } | % { [byte]$_ }))
#   bash:        openssl rand -base64 32
NEXTAUTH_SECRET=replace-me-with-a-long-random-string

# 로컬 dev URL (기본 포트 3001 기준)
NEXTAUTH_URL=http://localhost:3001

# Google OAuth Client (https://console.cloud.google.com/apis/credentials 에서 발급)
# Authorized redirect URIs 에 아래 URL을 등록해야 합니다:
#   http://localhost:3001/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
